# Copy to apps/web/.env.local and fill in values

# MapLibre — leave empty to use default OSM raster tiles
NEXT_PUBLIC_MAPLIBRE_STYLE_URL=

# Anthropic
ANTHROPIC_API_KEY=

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Upstash Redis
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# OSRM routing (public demo for dev, swap for self-hosted in prod)
OSRM_ENDPOINT=https://router.project-osrm.org
